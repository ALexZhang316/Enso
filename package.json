{
  "name": "enso-desktop-agent",
  "version": "0.1.0",
  "description": "Enso local-first Windows desktop personal agent",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "bootstrap:git": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/bootstrap-git.ps1",
    "bootstrap:git:commit": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/bootstrap-git.ps1 -InitialCommit",
    "dev:renderer": "cross-env VITE_CJS_IGNORE_WARNING=true vite --host localhost --port 5173 --strictPort",
    "dev:main": "tsc -p tsconfig.node.json --watch",
    "dev:electron": "wait-on http-get://localhost:5173 dist/main/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron ./dist/main/main.js",
    "dev": "concurrently --kill-others-on-fail \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:all-exit": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "build:renderer": "cross-env VITE_CJS_IGNORE_WARNING=true vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:main",
    "test:unit": "npm run build && cross-env ELECTRON_RUN_AS_NODE=1 electron tests/unit.test.cjs",
    "test:integration": "npm run build && cross-env ELECTRON_RUN_AS_NODE=1 electron tests/integration.test.cjs",
    "test:ui": "npm run build && node tests/ui.test.cjs",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:ui",
    "preflight": "npm run test:all",
    "verify": "npm run test:all",
    "postflight": "npm run verify && node scripts/check-docs-updated.cjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "start": "electron ./dist/main/main.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@langchain/core": "^0.3.69",
    "@langchain/openai": "^0.6.9",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "langchain": "^0.3.33",
    "lucide-react": "^0.538.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.57",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.4.19",
    "wait-on": "^8.0.5"
  }
}
